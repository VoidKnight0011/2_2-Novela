<Shell
    x:Class="Novela.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:auth="clr-namespace:Novela.Resources.Pages.Authentication"
    xmlns:main="clr-namespace:Novela.Resources.Pages.Book"
    FlyoutBehavior="Disabled">

    <!-- AUTH -->
    <ShellContent
        ContentTemplate="{DataTemplate auth:Novela_Auth}"
        Route="auth" />

    <!-- DASHBOARD -->
    <TabBar>
        <ShellContent
            Shell.ForegroundColor="{AppThemeBinding Light=#2C2C2C, Dark=#EAEAEA}"
            Shell.BackgroundColor="{AppThemeBinding Light=#EAEAEA, Dark=#2C2C2C}"
            ContentTemplate="{DataTemplate main:Novela_Dashboard}"
            Route="dashboard" />
        
        <ShellContent
            ContentTemplate="{DataTemplate main:Novela_Overview}"
            Route="overview" />
    </TabBar>

</Shell>