<Shell
    x:Class="Novela.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:auth="clr-namespace:Novela.Resources.Pages.Authentication"
    xmlns:main="clr-namespace:Novela.Resources.Pages.Book"
    xmlns:extra="clr-namespace:Novela.Resources.Pages.Extra"
    FlyoutBehavior="Disabled">

    <Shell.TitleView>
        <Label Text="Novela" VerticalOptions="Center" FontFamily="Sunborn-One" 
               FontSize="Large" TextColor="{AppThemeBinding Light=#1F1F1F, Dark=#EAEAEA}" />
    </Shell.TitleView>
    
    
    
    <!-- AUTH -->
    <ShellContent
        ContentTemplate="{DataTemplate auth:Novela_Auth}"
        Route="auth" />

    <!-- BOOKS -->
    <ShellContent
        ContentTemplate="{DataTemplate main:Novela_Dashboard}"
        Route="dashboard"
    />
    
</Shell>