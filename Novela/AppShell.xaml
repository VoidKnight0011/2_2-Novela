<Shell
    x:Class="Novela.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:auth="clr-namespace:Novela.Resources.Pages.Authentication"
    xmlns:main="clr-namespace:Novela.Resources.Pages.Book"
    FlyoutBehavior="Disabled">

    <!-- AUTH -->
    <ShellContent
        ContentTemplate="{DataTemplate auth:Novela_Auth}"
        Route="auth" />

    <!-- BOOKS -->
    <ShellContent
        Shell.ForegroundColor="{AppThemeBinding Light=#191919, Dark=#F5F5F5}"
        Shell.BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#191919}"
        ContentTemplate="{DataTemplate main:Novela_Dashboard}"
        Route="dashboard"
    />
        
        <ShellContent
            Shell.ForegroundColor="{AppThemeBinding Light=#191919, Dark=#F5F5F5}"
            Shell.BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#191919}"
            ContentTemplate="{DataTemplate main:Novela_Overview}"
            Route="overview"
        />

</Shell>