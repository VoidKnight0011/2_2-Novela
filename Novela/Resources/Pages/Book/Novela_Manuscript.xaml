<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="Novela.Resources.Pages.Book.Novela_Manuscript"
             Padding="0"
             BackgroundColor="{AppThemeBinding Light=#F4F4F4, Dark=#2C2C2C}">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">

            <!-- Section Management -->
            <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="10">
                
                <!-- Header -->
                <Label Grid.Row="0" Text="Sections (Arcs)" FontSize="12"
                       FontFamily="Poppins-Black" TextColor="{AppThemeBinding Light=#2C2C2C, Dark=#F4F4F4}" />

                <CollectionView x:Name="books_collection_list" IsVisible="False" Grid.Row="2" Margin="10, 0, 10, 10" ItemsSource="{Binding the_displayedbooks }" EmptyView="You have no Books to Display! Create one now!">
            <CollectionView.ItemsLayout>
                <GridItemsLayout Orientation="Vertical" Span="1" VerticalItemSpacing="8" HorizontalItemSpacing="6" />
            </CollectionView.ItemsLayout>

            <CollectionView.ItemTemplate>
                
                <DataTemplate>
                    <Border HeightRequest="50" StrokeThickness="0" StrokeShape="RoundRectangle 10" BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#191919}">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer CommandParameter="{Binding .}" Tapped="section_toggle"/>
                        </Border.GestureRecognizers>
                        
                        <Grid>
                            <Image VerticalOptions="Fill" HorizontalOptions="Fill" Source="{Binding book_cover}" Aspect="AspectFill" Opacity="0.6" />
                            
                            <Label Margin="15, 0" Grid.Column="1" Text="{Binding book_title}" VerticalOptions="Center" LineBreakMode="TailTruncation" MaxLines="1" HorizontalOptions="Start"
                                   FontFamily="Poppins-Light" FontSize="12" TextColor="{AppThemeBinding Light=#2C2C2C, Dark=#EAEAEA}" />
                            
                            <ImageButton x:Name="toggle_section" Margin="15, 0" CommandParameter="{Binding .}" Grid.Column="2"
                                         Source="{AppThemeBinding Light=novela_edit_light.png, Dark=novela_edit_dark.png}" HeightRequest="32" WidthRequest="32" MinimumHeightRequest="32" MinimumWidthRequest="32"
                                         Padding="5" VerticalOptions="Center" HorizontalOptions="End" Aspect="AspectFit"
                                         BackgroundColor="Transparent" />
                        </Grid>    
                    </Border>
                </DataTemplate>
                
            </CollectionView.ItemTemplate>
        </CollectionView>
                
            </Grid>

            <!-- Add Chapter Button -->
            <Border StrokeThickness="0" StrokeShape="RoundRectangle 8" Padding="12,10" HeightRequest="45"
                    BackgroundColor="#2E7D32">
                <!-- <Border.GestureRecognizers> -->
                <!--     <TapGestureRecognizer Tapped="on_addchapter" /> -->
                <!-- </Border.GestureRecognizers> -->
                <Border.Behaviors>
                    <toolkit:TouchBehavior PressedScale="0.95" DefaultAnimationDuration="80"/>
                </Border.Behaviors>
                <HorizontalStackLayout Spacing="8" HorizontalOptions="Center">
                    <Image Source="icon_add.png" HeightRequest="18" WidthRequest="18" VerticalOptions="Center" />
                    <Label Text="Add Chapter" VerticalOptions="Center" 
                           FontFamily="Poppins-Black" FontSize="12" TextColor="White"/>
                </HorizontalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>

</ContentView>