<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:views="clr-namespace:Novela.Resources.Pages.Extra"
             x:Class="Novela.Resources.Pages.Book.Novela_Manuscript"
             Padding="0">
    
        <ScrollView>
            <VerticalStackLayout Padding="20" Spacing="20">
                
                <!-- Title -->
                <Label Text="Manuscript" HorizontalTextAlignment="Center"
                       FontFamily="Poppins-Black" FontSize="24" 
                       TextColor="{AppThemeBinding Light=#2C2C2C, Dark=#F4F4F4}" />
                
                <!-- Manuscript Content Placeholder -->
                <Label Text="Manuscript editor goes here..." 
                       FontFamily="Poppins-Regular" FontSize="14"
                       TextColor="{AppThemeBinding Light=#2C2C2C, Dark=#F4F4F4}" />
                
            </VerticalStackLayout>
        </ScrollView>
 
</ContentView>