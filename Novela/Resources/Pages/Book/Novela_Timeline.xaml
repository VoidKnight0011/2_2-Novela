<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:views="clr-namespace:Novela.Resources.Pages.Extra"
             x:Class="Novela.Resources.Pages.Book.Novela_Timeline"
             Padding="0"
             BackgroundColor="{AppThemeBinding Light=#F4F4F4, Dark=#2C2C2C}">
    
        <ScrollView>
            <VerticalStackLayout Padding="20" Spacing="20">
                
                <!-- Title -->
                <Label Text="Timeline" HorizontalTextAlignment="Center"
                       FontFamily="Poppins-Black" FontSize="24" 
                       TextColor="{AppThemeBinding Light=#2C2C2C, Dark=#F4F4F4}" />
                
                <!-- Timeline Content Placeholder -->
                <Label Text="Timeline events will be displayed here..." 
                       FontFamily="Poppins-Regular" FontSize="14"
                       TextColor="{AppThemeBinding Light=#2C2C2C, Dark=#F4F4F4}" />
                
                <!-- Add Event Button -->
                <Button Text="Add Event" 
                        FontFamily="Poppins-Black" 
                        HeightRequest="45"
                        CornerRadius="8"
                        BackgroundColor="#2E7D32"
                        TextColor="White"
                        Clicked="on_addevent"/>
                
            </VerticalStackLayout>
        </ScrollView>
        
</ContentView>