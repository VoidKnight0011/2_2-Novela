<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:views="clr-namespace:Novela.Resources.Pages.Extra"
             x:Class="Novela.Resources.Pages.Book.Novela_Appendices"
             Padding="0">
    
    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Settings" Order="Secondary" Priority="0" Clicked="to_settings" />
        <ToolbarItem Text="About" Order="Secondary" Priority="1" Clicked="to_about" />
        <ToolbarItem Text="Logout" Order="Secondary" Priority="2" Clicked="to_logout" />
    </ContentPage.ToolbarItems>
    
    <Grid>    
        <!-- CONTENT -->
        <ScrollView Margin="60, 0, 0, 0">
            <VerticalStackLayout Padding="20" Spacing="20">
                
                <!-- Title -->
                <Label Text="Appendices" HorizontalTextAlignment="Center"
                       FontFamily="Poppins-Black" FontSize="24" 
                       TextColor="{AppThemeBinding Light=#2C2C2C, Dark=#F4F4F4}" />
                
                <!-- Tabs for Characters, Locations, etc. -->
                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="10">
                    <Button Grid.Column="0" Text="Characters" 
                            FontFamily="Poppins-Black" FontSize="12"
                            Clicked="on_showcharacters"/>
                    <Button Grid.Column="1" Text="Locations" 
                            FontFamily="Poppins-Black" FontSize="12"
                            Clicked="on_showlocations"/>
                    <Button Grid.Column="2" Text="Items" 
                            FontFamily="Poppins-Black" FontSize="12"
                            Clicked="on_showitems"/>
                </Grid>
                
                <!-- Content Area -->
                <Label Text="Appendix content will be displayed here..." 
                       FontFamily="Poppins-Regular" FontSize="14"
                       TextColor="{AppThemeBinding Light=#2C2C2C, Dark=#F4F4F4}" />
                
            </VerticalStackLayout>
        </ScrollView>
        
        <!-- SIDEBAR -->
        <views:Book_Sidebar ZIndex="2" x:Name="Sidebar" HorizontalOptions="Start" 
                            VerticalOptions="Fill" SafeAreaEdges="None"/>
    
    </Grid>    
</ContentPage>