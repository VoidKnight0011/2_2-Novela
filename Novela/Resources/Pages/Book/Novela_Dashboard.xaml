<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Novela.Resources.Pages.Book.Novela_Dashboard"
             Padding="0">
    
    <!-- Header -->
    <Shell.TitleView>
        <Label Text="Novella" VerticalOptions="Center" FontFamily="Sunborn-One" 
               FontSize="Large" TextColor="{AppThemeBinding Light=#1F1F1F, Dark=#EAEAEA}" />
    </Shell.TitleView>
    
    <ContentPage.ToolbarItems>
        
        <ToolbarItem Text="Settings" Order="Secondary" Priority="0"
                     Clicked="to_settings" />
        <ToolbarItem Text="About" Order="Secondary" Priority="1"
                     Clicked="to_about" />
        <ToolbarItem Text="Logout" Order="Secondary" Priority="2"
                     Clicked="to_logout" />
        
    </ContentPage.ToolbarItems>
    
    <!-- MAIN Layout -->
    <Grid RowDefinitions="auto, auto, *" VerticalOptions="Fill"
          BackgroundColor="{AppThemeBinding Light=#F4F4F4, Dark=#2C2C2C}">
        
        
        
        <!-- LAYER #1 -->
        <Grid Grid.Row="0" ColumnDefinitions="auto, *, auto" Padding="4, 0" VerticalOptions="Center" ColumnSpacing="5" Margin="10, 10, 10, 5">
            <Border Grid.Column="0" Padding="2,0" HeightRequest="40" WidthRequest="70" StrokeThickness="1" StrokeShape="RoundRectangle 8"
                    BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E1E1E}" Stroke="{AppThemeBinding Light=#DADADA, Dark=#3F3F3F}">
                <Picker Title="Status" ItemsSource="{Binding StatusOptions}" SelectedItem="{Binding DefaultStatus}" HorizontalOptions="Center" VerticalOptions="Center"
                        TextColor="{AppThemeBinding Light=#1F1F1F, Dark=#EAEAEA}" FontSize="Micro"/>
            </Border>
            
            <SearchBar Grid.Column="1" VerticalOptions="Center" Placeholder="Search through Books..." Margin="2,0"
                       TextColor="{AppThemeBinding Light=#1F1F1F, Dark=#EAEAEA}" PlaceholderColor="{AppThemeBinding Light=#5A5A5A, Dark=#BDBDBD}" />
            
            <Switch Grid.Column="2" IsToggled="True" />
        </Grid>
        
        <!-- LAYER #2 -->
        <Grid Grid.Row="1" Margin="10, 5" ColumnSpacing="5" Padding="2, 0">
            <Label Text="Your Books" FontSize="Small" />
        </Grid>
        
        <!-- LAYER #3 -->
        <CollectionView Grid.Row="2" Margin="10, 5, 10, 10" ItemsSource="{Binding testbooks}">
            <CollectionView.ItemsLayout>
                    <GridItemsLayout Orientation="Vertical" Span="2" />
            </CollectionView.ItemsLayout>
            
            <CollectionView.ItemTemplate>
                    
                    <DataTemplate>
                        
                        <!-- Card Content -->
                        <Border BackgroundColor="Gray" Margin="5" HeightRequest="250" StrokeShape="RoundRectangle 5">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="to_editbook"></TapGestureRecognizer>
                            </Border.GestureRecognizers>
                            
                            <Grid>
                                <Image Source="grid.png" Aspect="AspectFill" />
                                <Grid VerticalOptions="End" Padding="8" ColumnDefinitions="*, auto"
                                      BackgroundColor="#80000000">
                                    <!-- <BoxView Color="Black" Opacity="0.25" HeightRequest="Fill" WidthRequest="Fill" /> -->
                                    <Label Text="{Binding book_title}" VerticalOptions="Center" LineBreakMode="TailTruncation" MaxLines="1"
                                           TextColor="White"/>
                                    
                                    <ImageButton Source="icon_edit.png" HeightRequest="20" WidthRequest="20" Grid.Column="1" Clicked="book_options"
                                                 BackgroundColor="Transparent">

                                    </ImageButton>
                                </Grid>
                            </Grid>
                            
                        </Border>   
                        
                        
                    </DataTemplate>
                
            </CollectionView.ItemTemplate>
        </CollectionView>
        
        <!-- LAYER #4 -->
        <Border StrokeThickness="0" Grid.RowSpan="3" HorizontalOptions="End" VerticalOptions="End" Margin="25, 35" StrokeShape="RoundRectangle 5"
                BackgroundColor="Gray">
            <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="to_addbook" />
            </Border.GestureRecognizers>
            
            <HorizontalStackLayout VerticalOptions="Center" HorizontalOptions="Center">
                <Image Source="plus.png" HeightRequest="10" WidthRequest="10" VerticalOptions="Center" Margin="10, 10, 5, 10" />
                <Label Text="Add Book" TextColor="Black" VerticalOptions="Center" Margin="5, 10, 10, 10" />
            </HorizontalStackLayout>
        </Border>    
        
        
        
    </Grid>    
    

</ContentPage>
