<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Novela.Resources.Pages.Book.Novela_Dashboard">
    
    <!-- Header -->
    <Shell.TitleView>
        <Label Text="Novella" VerticalOptions="Center" FontFamily="Sunborn-One" 
               FontSize="Large" TextColor="{AppThemeBinding Light=#1F1F1F, Dark=#EAEAEA}" />
    </Shell.TitleView>
    
    <ContentPage.ToolbarItems>
        
        <ToolbarItem Text="Settings" Order="Secondary" Priority="0"
                     Clicked="OnSettings" />
        <ToolbarItem Text="About" Order="Secondary" Priority="1"
                     Clicked="OnAbout" />
        <ToolbarItem Text="Logout" Order="Secondary" Priority="2"
                     Clicked="OnLogout" />
        
    </ContentPage.ToolbarItems>
    
    <!-- MAIN Layout -->
    <Grid RowDefinitions="auto, auto, auto, *" ColumnDefinitions="*, auto" BackgroundColor="{AppThemeBinding Light=#F4F4F4, Dark=#2C2C2C}">
        
        <!-- LAYER #1 -->
        <Grid Grid.Row="0" RowDefinitions="auto, *" ColumnDefinitions="auto, *, auto" Padding="4, 0" VerticalOptions="Center" ColumnSpacing="5" Margin="0, 2.5">
            <Label Grid.Row="0" Text="Filter" Padding="2, 0"
                   TextColor="{AppThemeBinding Light=#1F1F1F, Dark=#EAEAEA}" />
            <Border Grid.Row="1" Grid.Column="0" Padding="2,0" HeightRequest="40" WidthRequest="70" StrokeThickness="1" StrokeShape="RoundRectangle 8"
                    BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E1E1E}" Stroke="{AppThemeBinding Light=#DADADA, Dark=#3F3F3F}">
                <Picker Title="Status" ItemsSource="{Binding StatusOptions}" SelectedItem="{Binding DefaultStatus}" HorizontalOptions="Center" VerticalOptions="Center"
                        TextColor="{AppThemeBinding Light=#1F1F1F, Dark=#EAEAEA}" FontSize="Micro"/>
            </Border>
            
            <SearchBar Grid.Row="1" Grid.Column="1" VerticalOptions="Center" Placeholder="Search through Books..." Margin="2,0"
                       TextColor="{AppThemeBinding Light=#1F1F1F, Dark=#EAEAEA}" PlaceholderColor="{AppThemeBinding Light=#5A5A5A, Dark=#BDBDBD}" />
            
            <Switch Grid.Row="1" Grid.Column="2" IsToggled="True" />
        </Grid>
        
        <!-- LAYER #2 -->
        <Grid Grid.Row="2" Margin="0, 2.5" ColumnSpacing="5" Padding="2, 0">
            <Label Text="Dashboard" />
        </Grid>
        
        <!-- LAYER #3 -->
        <Border Grid.Row="3" Margin="0, 2.5" StrokeThickness="0">
            <Grid ColumnDefinitions="*,*">
                
                <Border BackgroundColor="Gray" Margin="5" HeightRequest="250" StrokeShape="RoundRectangle 5">
                            <Grid>
                                <Image Source="grid.png" Aspect="AspectFill" />
                                <Grid VerticalOptions="End" Padding="8" ColumnDefinitions="*, auto"
                                      BackgroundColor="#80000000">
                                    
                                    <Label Text="Yes" VerticalOptions="Center" 
                                           TextColor="White"/>
                                    
                                    <ImageButton Source="icon_kebab.png" HeightRequest="20" WidthRequest="20" Grid.Column="1" Clicked="OnBookOptionsClicked"
                                                 BackgroundColor="Transparent" />

                                </Grid>
                            </Grid>
                        </Border>   
                
            </Grid>
        </Border>
        
        <!-- LAYER #4 -->
        <Border HorizontalOptions="End" VerticalOptions="End" Margin="20" Grid.RowSpan="4"
            HeightRequest="40" WidthRequest="120" StrokeShape="RoundRectangle 5" BackgroundColor="White">
            <Border.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnTapped" />
            </Border.GestureRecognizers>
            <HorizontalStackLayout>
                <Image Source="plus.png" HeightRequest="10" WidthRequest="10" />
                <Label Text="Add Book" />
            </HorizontalStackLayout>
        </Border>    
        
    </Grid>    

</ContentPage>
