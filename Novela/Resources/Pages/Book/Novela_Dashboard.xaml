<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="Novela.Resources.Pages.Book.Novela_Dashboard"
             Padding="0">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Settings" Order="Secondary" Priority="0" Clicked="to_settings"/>
        <ToolbarItem Text="About" Order="Secondary" Priority="1" Clicked="to_about" />
        <ToolbarItem Text="Logout"   Order="Secondary" Priority="2" Clicked="to_logout" />
    </ContentPage.ToolbarItems>

    <Grid RowDefinitions="Auto, Auto, *" RowSpacing="5"
          BackgroundColor="{AppThemeBinding Light=#F4F4F4, Dark=#2C2C2C}">

        <!-- LAYER #1 — Filter / Search / Toggle -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto, *, Auto" Padding="16, 8">

            <Border Grid.Column="0" Padding="10, 2.5" HorizontalOptions="Fill" StrokeThickness="2.5" StrokeShape="RoundRectangle 8" HeightRequest="40"
                    BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E1E1E}" Stroke="{AppThemeBinding Light=#2C2C2C, Dark=#F4F4F4}">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="to_filter" />
                </Border.GestureRecognizers>
                <Border.Behaviors>
                    <toolkit:TouchBehavior PressedScale="0.90" DefaultAnimationDuration="80"/>
                </Border.Behaviors>
                
                <HorizontalStackLayout>
                        <Image Source="icon_settings.png" HeightRequest="17.5" Width="17.5" Margin="2.5" VerticalOptions="Center" />
                        <Label Text="Filter" Margin="2.5" VerticalOptions="Center"
                               FontFamily="Poppins-Black" FontSize="12" TextColor="{AppThemeBinding Light=#1F1F1F, Dark=#EAEAEA}"/>
                    </HorizontalStackLayout>   
            </Border>
            
            <SearchBar Grid.Column="1" VerticalOptions="Center" Placeholder="Search books..."
                       FontFamily="Poppins-Regular" FontSize="13" TextColor="{AppThemeBinding Light=#1F1F1F, Dark=#EAEAEA}" PlaceholderColor="{AppThemeBinding Light=#9E9E9E, Dark=#757575}" />

            <ImageButton Grid.Column="2" x:Name="grid_toggle" Clicked="toggle_grid" WidthRequest="25" HeightRequest="25" MinimumHeightRequest="25" MinimumWidthRequest="25" Source="icon_grid.png" VerticalOptions="Center" />
        </Grid>

        <!-- LAYER #2 — Section Label -->
        <Label Grid.Row="1" Text="Your Books" FontSize="14" Padding="16, -2.5, 16, -5" HorizontalOptions="Start" HorizontalTextAlignment="Start"
               FontFamily="Poppins-Black" TextColor="{AppThemeBinding Light=#2C2C2C, Dark=#F4F4F4}" />

        <!-- LAYER #3 — Book Grid -->
        <CollectionView x:Name="books_collection_grid" IsVisible="True" Grid.Row="2" Margin="10, 0, 10, 10" ItemsSource="{Binding the_displayedbooks }" EmptyView="You have no Books to Display! Create one now!">
            <CollectionView.ItemsLayout>
                <GridItemsLayout Orientation="Vertical" Span="2" VerticalItemSpacing="8" HorizontalItemSpacing="6" />
            </CollectionView.ItemsLayout>

            <CollectionView.ItemTemplate>
                
                <DataTemplate>
                    <Border HeightRequest="230" StrokeThickness="0" StrokeShape="RoundRectangle 10">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer CommandParameter="{Binding .}" Tapped="to_editbook"/>
                        </Border.GestureRecognizers>
                        
                        <Grid>
                            <Image x:Name="books_collection_image" Source="{Binding book_cover, FallbackValue='placeholder_image.png'}" Aspect="AspectFill" />
                            <BoxView>
                                <BoxView.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#00000000" Offset="0.0"/>
                                        <GradientStop Color="#99000000" Offset="1.0"/>
                                    </LinearGradientBrush>
                                </BoxView.Background>
                            </BoxView>
                            
                            <Grid VerticalOptions="End" Padding="8, 12" ColumnDefinitions="*, Auto"
                                  BackgroundColor="{AppThemeBinding Light=#BFFFFFFF, Dark=#BF000000}">
                                <Label Grid.Column="0" Text="{Binding book_title}" VerticalOptions="Center" LineBreakMode="TailTruncation" MaxLines="1"
                                       FontFamily="Poppins-Light" FontSize="12" TextColor="{AppThemeBinding Light=#2C2C2C, Dark=#EAEAEA}" />
                                <ImageButton Clicked="book_options" CommandParameter="{Binding .}" Grid.Column="1" ZIndex=""
                                             Source="{AppThemeBinding Light=novela_edit_light.png, Dark=novela_edit_dark.png}" HeightRequest="32" WidthRequest="32" MinimumHeightRequest="32" MinimumWidthRequest="32"
                                             Padding="5" VerticalOptions="Center" Aspect="AspectFit"
                                             BackgroundColor="Transparent" />
                            </Grid>
                            
                        </Grid>
                    </Border>
                </DataTemplate>
                
            </CollectionView.ItemTemplate>
        </CollectionView>
        
        <CollectionView x:Name="books_collection_list" IsVisible="False" Grid.Row="2" Margin="10, 0, 10, 10" ItemsSource="{Binding the_displayedbooks }" EmptyView="You have no Books to Display! Create one now!">
            <CollectionView.ItemsLayout>
                <GridItemsLayout Orientation="Vertical" Span="1" VerticalItemSpacing="8" HorizontalItemSpacing="6" />
            </CollectionView.ItemsLayout>

            <CollectionView.ItemTemplate>
                
                <DataTemplate>
                    <Border HeightRequest="50" StrokeThickness="0" StrokeShape="RoundRectangle 10" BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#191919}">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer CommandParameter="{Binding .}" Tapped="to_editbook"/>
                        </Border.GestureRecognizers>
                        
                        <Grid>
                            <Image VerticalOptions="Fill" HorizontalOptions="Fill" Source="{Binding book_cover}" Aspect="AspectFill" Opacity="0.6" />
                            
                            <Label Margin="15, 0" Grid.Column="1" Text="{Binding book_title}" VerticalOptions="Center" LineBreakMode="TailTruncation" MaxLines="1" HorizontalOptions="Start"
                                   FontFamily="Poppins-Light" FontSize="12" TextColor="{AppThemeBinding Light=#2C2C2C, Dark=#EAEAEA}" />
                            
                            <ImageButton Margin="15, 0" Clicked="book_options" CommandParameter="{Binding .}" Grid.Column="2" ZIndex=""
                                         Source="{AppThemeBinding Light=novela_edit_light.png, Dark=novela_edit_dark.png}" HeightRequest="32" WidthRequest="32" MinimumHeightRequest="32" MinimumWidthRequest="32"
                                         Padding="5" VerticalOptions="Center" HorizontalOptions="End" Aspect="AspectFit"
                                         BackgroundColor="Transparent" />
                        </Grid>    
                    </Border>
                </DataTemplate>
                
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- LAYER #4 — FAB -->
        <Border StrokeThickness="1" Grid.Row="2" HorizontalOptions="End" VerticalOptions="End" Margin="15, 30" StrokeShape="RoundRectangle 10" Padding="1"
                BackgroundColor="#4A90D9" Stroke="#234263">
            <Border.GestureRecognizers>
                <TapGestureRecognizer Tapped="to_addbook" />
            </Border.GestureRecognizers>
            <Border.Behaviors>
                <toolkit:TouchBehavior PressedScale="0.90" DefaultAnimationDuration="80"/>
            </Border.Behaviors>

            <HorizontalStackLayout Spacing="5" Padding="12, 8">
                <Image Source="icon_add.png" HeightRequest="20" WidthRequest="20" VerticalOptions="Center" />
                <Label Text="Add Book" VerticalOptions="Center" CharacterSpacing="-0.5"
                       FontFamily="Poppins-Black" FontSize="13" TextColor="#234263"/>
            </HorizontalStackLayout>
        </Border>

    </Grid>
</ContentPage>