<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Novela.Resources.Pages.Book.Novela_Overview"
             Padding="0">
    
        <ScrollView>
            <VerticalStackLayout Padding="20" Spacing="20">
                
                <!-- Row#2: Book Details -->
                <Grid RowDefinitions="*, Auto">
                    <Grid Grid.Row="0" ColumnDefinitions="*,*" VerticalOptions="Start" ColumnSpacing="12">

                        <!-- COLUMN#1: Book Image -->
                        <Border Grid.Column="0" StrokeThickness="0" StrokeShape="RoundRectangle 5" HeightRequest="200">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="on_editcover" />
                            </Border.GestureRecognizers>
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0 " EndPoint="0, 1">
                                    <GradientStop Color="#00000000" Offset="0.0" />
                                    <GradientStop Color="#66000000" Offset="1.0" />
                                </LinearGradientBrush>
                            </Border.Background>
                            
                            <Grid>
                                <Image Source="{Binding CurrentBook.book_cover}" Aspect="AspectFill" VerticalOptions="Center" HorizontalOptions="Center" />

                                <Grid BackgroundColor="#66000000">
                                    <Label Text="📷 Tap to Edit Cover" HorizontalOptions="Center" VerticalOptions="Center" 
                                           FontSize="Micro" FontFamily="Poppins-Regular" TextColor="White" />
                                </Grid>
                            </Grid>
                        </Border>

                        <!-- COLUMN#2: Book Information -->
                        <Grid Grid.Column="1" RowDefinitions="*,Auto" RowSpacing="7.5">
                            
                            <!-- Info: Description -->
                            <Grid Grid.RowDefinitions="Auto, *" Grid.Row="0" HorizontalOptions="Fill">

                                <Label Grid.Row="0" x:Name="book_description" Text="Description" FontSize="12"
                                       FontFamily="Poppins-Black" TextColor="{AppThemeBinding Light=#2C2C2C, Dark=#F4F4F4}"/>

                                <Border Grid.Row="1" StrokeThickness="1" StrokeShape="RoundRectangle 8" Padding="10,6" VerticalOptions="Fill"
                                        BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E1E1E}" Stroke="{AppThemeBinding Light=#DADADA, Dark=#3F3F3F}">

                                    <Editor Placeholder="Enter Book Description..." FontSize="8" Text="{Binding CurrentBook.book_description, Mode=TwoWay}" VerticalOptions="Fill" AutoSize="Disabled"
                                            FontFamily="Poppins-Light" TextColor="{AppThemeBinding Light=#2C2C2C, Dark=#F4F4F4}" PlaceholderColor="{AppThemeBinding Light=#9E9E9E, Dark=#757575}"/>
                                </Border>
                            </Grid>
                            
                            <!-- Info: Status -->
                            <Grid Grid.Row="1" HeightRequest="30" ColumnDefinitions="*,*">
                                <Label Grid.Column="0" Text="Status" FontSize="12" VerticalOptions="Center" HorizontalOptions="Start"
                                       FontFamily="Poppins-Black" TextColor="{AppThemeBinding Light=#2C2C2C, Dark=#F4F4F4}"/>

                                <Border Grid.Column="1" Padding="6,0" StrokeThickness="1.5" StrokeShape="RoundRectangle 8" VerticalOptions="Center" HeightRequest="37.5" WidthRequest="65"
                                        BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E1E1E}" Stroke="{AppThemeBinding Light=#DADADA, Dark=#3F3F3F}">
                                    <Picker x:Name="book_status" Margin="0" Title="Status" ItemsSource="{Binding status_options}" SelectedItem="{Binding CurrentBook.book_status, Mode=TwoWay}" HorizontalOptions="Center" VerticalOptions="Center"
                                            FontFamily="Poppins-Regular" FontSize="10" TextColor="{AppThemeBinding Light=#1F1F1F, Dark=#EAEAEA}" />
                                </Border>
                            </Grid>

                        </Grid>
                    </Grid>

                    <!-- COLUMN#2-ROW#2: Buttons -->
                        <Grid Grid.Row="1" ColumnDefinitions="*,*" ColumnSpacing="10" Margin="0,10,0,0">

                            <Button Grid.Column="0" Text="Delete" Clicked="on_delete" FontSize="10" HeightRequest="42" CornerRadius="8" BorderWidth="0" HorizontalOptions="Fill" VerticalOptions="Center"
                                    FontFamily="Poppins-Black" TextColor="{AppThemeBinding Light=#2C2C2C, Dark=#F4F4F4}" BackgroundColor="{AppThemeBinding Light=#E0E0E0, Dark=#3F3F3F}"/>

                            <Button Grid.Column="1" Text="Save" Clicked="on_save" FontSize="8" HeightRequest="42" CornerRadius="8" BorderWidth="0" HorizontalOptions="Fill" VerticalOptions="Center" 
                                    FontFamily="Poppins-Black" TextColor="White" BackgroundColor="#2E7D32"/>
                        </Grid>

                </Grid>

                <!-- Row#3: Genre -->
                <Grid RowDefinitions="*,*" RowSpacing="5">
                    <Label Text="Genre" FontSize="12" Grid.Row="0"
                           FontFamily="Poppins-Black" TextColor="{AppThemeBinding Light=#2C2C2C, Dark=#F4F4F4}" />
                    
                    <!-- Genre Checkboxes (3 columns) -->
                    <CollectionView ItemsSource="{Binding GenreOptions}" Grid.Row="1">
                        <CollectionView.ItemsLayout>
                            <GridItemsLayout Span="3" Orientation="Vertical" HorizontalItemSpacing="2" VerticalItemSpacing="2"/>
                        </CollectionView.ItemsLayout>
                        
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="*,*" Column="2">
                                    <CheckBox Grid.Column="0" WidthRequest="2.5" HeightRequest="2.5" VerticalOptions="Center" CheckedChanged="on_genretoggle" Loaded="on_genreloaded"
                                              Color="#4A90D9" />
                                    <Label Grid.Column="1" Text="{Binding .}" FontSize="8" VerticalOptions="Center" LineBreakMode="TailTruncation" MaxLines="1"
                                           FontFamily="Poppins-Regular" TextColor="{AppThemeBinding Light=#1F1F1F, Dark=#EAEAEA}" />
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                        
                    </CollectionView>
                </Grid>

                <!-- Row#4: Intended Themes -->
                <Grid RowDefinitions="*,*">
                    <Label Text="Intended Themes" FontSize="12" Grid.Row="0"
                           FontFamily="Poppins-Black" TextColor="{AppThemeBinding Light=#2C2C2C, Dark=#F4F4F4}" />
                    
                    <Grid Grid.Row="1" ColumnDefinitions="*, Auto" ColumnSpacing="8" HorizontalOptions="Start">
                        <Border Grid.Column="0" StrokeThickness="1" StrokeShape="RoundRectangle 8" Padding="10,2.5" HeightRequest="40"
                                Stroke="{AppThemeBinding Light=#DADADA, Dark=#3F3F3F}" BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E1E1E}">
                            <Entry Placeholder="e.g., Redemption, Betrayal" x:Name="ThemeEntry" FontSize="8"
                                   FontFamily="Poppins-Regular" TextColor="{AppThemeBinding Light=#1F1F1F, Dark=#EAEAEA}" PlaceholderColor="{AppThemeBinding Light=#9E9E9E, Dark=#757575}" BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E1E1E}" />
                        </Border>
                        
                        <ImageButton Grid.Column="1" Source="icon_add.png" HeightRequest="3" WidthRequest="3" CornerRadius="12" Padding="3"
                                    BackgroundColor="#4A90D9"/>
                    </Grid>
                </Grid>
                
            </VerticalStackLayout>    
        </ScrollView>
    
</ContentView>