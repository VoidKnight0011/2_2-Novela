<?xml version="1.0" encoding="utf-8" ?>

<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="Novela.Resources.Pages.Book.Novela_Characters"
             BackgroundColor="{AppThemeBinding Light=#F4F4F4, Dark=#202020}">

    <Grid>
        <ScrollView>

            <VerticalStackLayout Padding="20,24,20,120"
                                 Spacing="34">

                <!-- HERO -->
                <VerticalStackLayout Spacing="28">

                    <!-- HEADER -->
                    <VerticalStackLayout Spacing="2">

                        <Label Text="Characters"
                               FontSize="26"
                               FontFamily="Poppins-Black"
                               TextColor="{AppThemeBinding Light=#202020, Dark=#F5F5F5}" />

                        <Label Text="Main cast and supporting roles"
                               FontSize="12"
                               FontFamily="Poppins-Regular"
                               TextColor="{AppThemeBinding Light=#707070, Dark=#A0A0A0}" />

                    </VerticalStackLayout>

                    <!-- PROTAGONISTS -->
                    <Grid RowDefinitions="Auto,*"
                          RowSpacing="10">

                        <HorizontalStackLayout Grid.Row="0"
                                               Spacing="6">

                            <Label Text="Protagonists"
                                   FontSize="15"
                                   FontFamily="Poppins-Black"
                                   TextColor="{AppThemeBinding Light=#202020, Dark=#F5F5F5}" />

                            <Label Text="Main characters"
                                   VerticalOptions="End"
                                   Margin="0,0,0,1"
                                   FontSize="10"
                                   FontFamily="Poppins-Regular"
                                   TextColor="{AppThemeBinding Light=#909090, Dark=#B0B0B0}" />

                        </HorizontalStackLayout>

                        <Border Grid.Row="1"
                                HeightRequest="235"
                                Padding="14"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 24"
                                BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#2A2A2A}">

                            <Grid>

                                <CollectionView ItemsSource="{Binding protagonist_characters}">

                                    <CollectionView.ItemsLayout>
                                        <LinearItemsLayout Orientation="Horizontal"
                                                           ItemSpacing="16" />
                                    </CollectionView.ItemsLayout>

                                    <CollectionView.ItemTemplate>

                                        <DataTemplate>

                                            <Border WidthRequest="145"
                                                    HeightRequest="190"
                                                    Padding="10"
                                                    StrokeThickness="0"
                                                    StrokeShape="RoundRectangle 18"
                                                    BackgroundColor="{AppThemeBinding Light=#F7F7F7, Dark=#343434}">

                                                <VerticalStackLayout Spacing="10">

                                                    <Border HeightRequest="118"
                                                            WidthRequest="118"
                                                            HorizontalOptions="Center"
                                                            StrokeThickness="0"
                                                            StrokeShape="RoundRectangle 14"
                                                            BackgroundColor="#3A3A3A">

                                                        <Image Source="{Binding character_image}"
                                                               Aspect="AspectFill" />

                                                    </Border>

                                                    <VerticalStackLayout Spacing="2">

                                                        <Label Text="{Binding character_name}"
                                                               HorizontalTextAlignment="Center"
                                                               LineBreakMode="TailTruncation"
                                                               MaxLines="1"
                                                               FontSize="12"
                                                               FontFamily="Poppins-Black"
                                                               TextColor="{AppThemeBinding Light=#202020, Dark=#F5F5F5}" />

                                                        <Label Text="{Binding character_role}"
                                                               HorizontalTextAlignment="Center"
                                                               LineBreakMode="TailTruncation"
                                                               MaxLines="1"
                                                               FontSize="9"
                                                               FontFamily="Poppins-Regular"
                                                               TextColor="{AppThemeBinding Light=#707070, Dark=#B0B0B0}" />

                                                    </VerticalStackLayout>

                                                </VerticalStackLayout>

                                            </Border>

                                        </DataTemplate>

                                    </CollectionView.ItemTemplate>

                                </CollectionView>

                                <Label Text="No protagonists added yet..."
                                       IsVisible="{Binding protagonist_empty}"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"
                                       FontSize="11"
                                       FontFamily="Poppins-Regular"
                                       TextColor="#8A8A8A" />

                            </Grid>

                        </Border>

                    </Grid>

                    <!-- ANTAGONISTS -->
                    <Grid RowDefinitions="Auto,*"
                          RowSpacing="10">

                        <HorizontalStackLayout Grid.Row="0"
                                               Spacing="6">

                            <Label Text="Antagonists"
                                   FontSize="15"
                                   FontFamily="Poppins-Black"
                                   TextColor="{AppThemeBinding Light=#202020, Dark=#F5F5F5}" />

                            <Label Text="Opposing force"
                                   VerticalOptions="End"
                                   Margin="0,0,0,1"
                                   FontSize="10"
                                   FontFamily="Poppins-Regular"
                                   TextColor="{AppThemeBinding Light=#909090, Dark=#B0B0B0}" />

                        </HorizontalStackLayout>

                        <Border Grid.Row="1"
                                HeightRequest="235"
                                Padding="14"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 24"
                                BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#2A2A2A}">

                            <Grid>

                                <CollectionView ItemsSource="{Binding antagonist_characters}">

                                    <CollectionView.ItemsLayout>
                                        <LinearItemsLayout Orientation="Horizontal"
                                                           ItemSpacing="16" />
                                    </CollectionView.ItemsLayout>

                                    <CollectionView.ItemTemplate>

                                        <DataTemplate>

                                            <Border WidthRequest="145"
                                                    HeightRequest="190"
                                                    Padding="10"
                                                    StrokeThickness="0"
                                                    StrokeShape="RoundRectangle 18"
                                                    BackgroundColor="{AppThemeBinding Light=#F7F7F7, Dark=#343434}">

                                                <VerticalStackLayout Spacing="10">

                                                    <Border HeightRequest="118"
                                                            WidthRequest="118"
                                                            HorizontalOptions="Center"
                                                            StrokeThickness="0"
                                                            StrokeShape="RoundRectangle 14"
                                                            BackgroundColor="#3A3A3A">

                                                        <Image Source="{Binding character_image}"
                                                               Aspect="AspectFill" />

                                                    </Border>

                                                    <VerticalStackLayout Spacing="2">

                                                        <Label Text="{Binding character_name}"
                                                               HorizontalTextAlignment="Center"
                                                               LineBreakMode="TailTruncation"
                                                               MaxLines="1"
                                                               FontSize="12"
                                                               FontFamily="Poppins-Black"
                                                               TextColor="{AppThemeBinding Light=#202020, Dark=#F5F5F5}" />

                                                        <Label Text="{Binding character_role}"
                                                               HorizontalTextAlignment="Center"
                                                               LineBreakMode="TailTruncation"
                                                               MaxLines="1"
                                                               FontSize="9"
                                                               FontFamily="Poppins-Regular"
                                                               TextColor="{AppThemeBinding Light=#707070, Dark=#B0B0B0}" />

                                                    </VerticalStackLayout>

                                                </VerticalStackLayout>

                                            </Border>

                                        </DataTemplate>

                                    </CollectionView.ItemTemplate>

                                </CollectionView>

                                <Label Text="No antagonists added yet..."
                                       IsVisible="{Binding antagonist_empty}"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"
                                       FontSize="11"
                                       FontFamily="Poppins-Regular"
                                       TextColor="#8A8A8A" />

                            </Grid>

                        </Border>

                    </Grid>

                </VerticalStackLayout>

                <!-- DIVIDER -->
                <BoxView HeightRequest="1"
                         Opacity="0.08"
                         BackgroundColor="{AppThemeBinding Light=Black, Dark=White}" />

                <!-- SUPPORTING SECTION -->
                <VerticalStackLayout Spacing="26">

                    <Label Text="Supporting Cast"
                           FontSize="18"
                           FontFamily="Poppins-Black"
                           TextColor="{AppThemeBinding Light=#202020, Dark=#F5F5F5}" />

                    <!-- SUPPORTING -->
                    <Grid RowDefinitions="Auto,*"
                          RowSpacing="10">

                        <Label Grid.Row="0"
                               Text="Supporting"
                               FontSize="13"
                               FontFamily="Poppins-Black"
                               TextColor="{AppThemeBinding Light=#303030, Dark=#F0F0F0}" />

                        <Border Grid.Row="1"
                                HeightRequest="175"
                                Padding="12"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 20"
                                BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#2A2A2A}">

                            <Grid>

                                <CollectionView ItemsSource="{Binding supporting_characters}">

                                    <CollectionView.ItemsLayout>
                                        <LinearItemsLayout Orientation="Horizontal"
                                                           ItemSpacing="12" />
                                    </CollectionView.ItemsLayout>

                                    <CollectionView.ItemTemplate>

                                        <DataTemplate>

                                            <Border WidthRequest="100"
                                                    Padding="8"
                                                    StrokeThickness="0"
                                                    StrokeShape="RoundRectangle 14"
                                                    BackgroundColor="{AppThemeBinding Light=#F7F7F7, Dark=#343434}">

                                                <VerticalStackLayout Spacing="8">

                                                    <Border HeightRequest="72"
                                                            WidthRequest="72"
                                                            HorizontalOptions="Center"
                                                            StrokeThickness="0"
                                                            StrokeShape="RoundRectangle 12"
                                                            BackgroundColor="#3A3A3A">

                                                        <Image Source="{Binding character_image}"
                                                               Aspect="AspectFill" />

                                                    </Border>

                                                    <Label Text="{Binding character_name}"
                                                           HorizontalTextAlignment="Center"
                                                           LineBreakMode="TailTruncation"
                                                           MaxLines="1"
                                                           FontSize="9"
                                                           FontFamily="Poppins-Medium"
                                                           TextColor="{AppThemeBinding Light=#202020, Dark=#F5F5F5}" />

                                                </VerticalStackLayout>

                                            </Border>

                                        </DataTemplate>

                                    </CollectionView.ItemTemplate>

                                </CollectionView>

                                <Label Text="No supporting characters yet..."
                                       IsVisible="{Binding supporting_empty}"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"
                                       FontSize="10"
                                       FontFamily="Poppins-Regular"
                                       TextColor="#8A8A8A" />

                            </Grid>

                        </Border>

                    </Grid>

                    <!-- MINOR -->
                    <Grid RowDefinitions="Auto,*"
                          RowSpacing="10">

                        <Label Grid.Row="0"
                               Text="Minor Characters"
                               FontSize="13"
                               FontFamily="Poppins-Black"
                               TextColor="{AppThemeBinding Light=#303030, Dark=#F0F0F0}" />

                        <Border Grid.Row="1"
                                HeightRequest="175"
                                Padding="12"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 20"
                                BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#2A2A2A}">

                            <Grid>

                                <CollectionView ItemsSource="{Binding minor_characters}">

                                    <CollectionView.ItemsLayout>
                                        <LinearItemsLayout Orientation="Horizontal"
                                                           ItemSpacing="12" />
                                    </CollectionView.ItemsLayout>

                                    <CollectionView.ItemTemplate>

                                        <DataTemplate>

                                            <Border WidthRequest="100"
                                                    Padding="8"
                                                    StrokeThickness="0"
                                                    StrokeShape="RoundRectangle 14"
                                                    BackgroundColor="{AppThemeBinding Light=#F7F7F7, Dark=#343434}">

                                                <VerticalStackLayout Spacing="8">

                                                    <Border HeightRequest="72"
                                                            WidthRequest="72"
                                                            HorizontalOptions="Center"
                                                            StrokeThickness="0"
                                                            StrokeShape="RoundRectangle 12"
                                                            BackgroundColor="#3A3A3A">

                                                        <Image Source="{Binding character_image}"
                                                               Aspect="AspectFill" />

                                                    </Border>

                                                    <Label Text="{Binding character_name}"
                                                           HorizontalTextAlignment="Center"
                                                           LineBreakMode="TailTruncation"
                                                           MaxLines="1"
                                                           FontSize="9"
                                                           FontFamily="Poppins-Medium"
                                                           TextColor="{AppThemeBinding Light=#202020, Dark=#F5F5F5}" />

                                                </VerticalStackLayout>

                                            </Border>

                                        </DataTemplate>

                                    </CollectionView.ItemTemplate>

                                </CollectionView>

                                <Label Text="No minor characters yet..."
                                       IsVisible="{Binding minor_empty}"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"
                                       FontSize="10"
                                       FontFamily="Poppins-Regular"
                                       TextColor="#8A8A8A" />

                            </Grid>

                        </Border>

                    </Grid>

                </VerticalStackLayout>

            </VerticalStackLayout>

        </ScrollView>

        <!-- FLOATING BUTTON -->
        <Border HorizontalOptions="End"
                VerticalOptions="End"
                Margin="20"
                Padding="4"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 18"
                BackgroundColor="{AppThemeBinding Light=#202020, Dark=#F5F5F5}">

            <Border.GestureRecognizers>
                <TapGestureRecognizer Tapped="on_addcharacter" />
            </Border.GestureRecognizers>

            <Border.Behaviors>
                <toolkit:TouchBehavior PressedScale="0.94"
                                       DefaultAnimationDuration="80" />
            </Border.Behaviors>

            <HorizontalStackLayout Padding="18,12"
                                   Spacing="8">

                <Image Source="icon_add.png"
                       HeightRequest="18"
                       WidthRequest="18" />

                <Label Text="Add Character"
                       VerticalOptions="Center"
                       FontSize="12"
                       FontFamily="Poppins-Black"
                       TextColor="{AppThemeBinding Light=#FFFFFF, Dark=#202020}" />

            </HorizontalStackLayout>

        </Border>

    </Grid>

</ContentView>