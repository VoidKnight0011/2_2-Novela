<?xml version="1.0" encoding="utf-8" ?>

<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="Novela.Resources.Pages.Book.Novela_Characters"
             BackgroundColor="{AppThemeBinding Light=#F4F4F4, Dark=#2C2C2C}">

    <Grid VerticalOptions="Fill" HorizontalOptions="Fill">
    <!-- INNER -->
        <ScrollView Margin="10, 7.5">
            <Grid RowDefinitions="*,*,*,*" RowSpacing="25">
            
                <!-- CHARACTERS: Protagonist -->
                <VerticalStackLayout Grid.Row="0" Spacing="0" VerticalOptions="Fill" HeightRequest="175">
                    <Label Text="Protagonist" Grid.Row="0"
                           FontSize="12" FontFamily="Poppins-Black" TextColor="{AppThemeBinding Light=#202020, Dark=#F5F5F5}" />
                    <Border Grid.Row="1" VerticalOptions="Fill" HeightRequest="165" StrokeShape="RoundRectangle 5" StrokeThickness="0"
                        BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#1F1F1F}">
                            <CollectionView>
                                <CollectionView.ItemsLayout>
                                    <GridItemsLayout Orientation="Horizontal" />
                                </CollectionView.ItemsLayout>
                                
                                <CollectionView.ItemTemplate>
                                    <DataTemplate>
                                        <Border VerticalOptions="Fill" StrokeThickness="0" StrokeShape="RoundRectangle 10"
                                                BackgroundColor="Black">
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer CommandParameter="{Binding .}" Tapped="to_charprofile"/>
                                            </Border.GestureRecognizers>
                                            
                                            <Grid>
                                                <Image x:Name="books_collection_image" Source="{Binding book_cover, FallbackValue='placeholder_image.png'}" Aspect="AspectFill" />
                                                <Border>
                                                    <Border.Background>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                            <GradientStop Color="#00000000" Offset="0.0"/>
                                                            <GradientStop Color="#99000000" Offset="1.0"/>
                                                        </LinearGradientBrush>
                                                    </Border.Background>
                                                </Border>
                                                
                                                <Grid VerticalOptions="End" Padding="8, 12" ColumnDefinitions="*, Auto"
                                                      BackgroundColor="{AppThemeBinding Light=#BFFFFFFF, Dark=#BF000000}">
                                                    <Label Grid.Column="0" Text="{Binding book_title}" VerticalOptions="Center" LineBreakMode="TailTruncation" MaxLines="1"
                                                           FontFamily="Poppins-Light" FontSize="12" TextColor="{AppThemeBinding Light=#2C2C2C, Dark=#EAEAEA}" />
                                                </Grid>
                                                
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                    
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                    </Border>    
                    
                </VerticalStackLayout>
                
                <!-- CHARACTERS: Antagonist -->
                <VerticalStackLayout Grid.Row="1" Spacing="0" VerticalOptions="Fill" HeightRequest="175">
                    <Label Text="Antagonist" Grid.Row="0"
                           FontSize="12" FontFamily="Poppins-Black" TextColor="{AppThemeBinding Light=#202020, Dark=#F5F5F5}" />
                    <Border Grid.Row="1" HeightRequest="165" StrokeShape="RoundRectangle 5" StrokeThickness="0"
                        BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#1F1F1F}">
                            <CollectionView>
                                <CollectionView.ItemsLayout>
                                    <GridItemsLayout Orientation="Horizontal" />
                                </CollectionView.ItemsLayout>
                                
                                <CollectionView.ItemTemplate>
                                    <DataTemplate>
                                        <Border VerticalOptions="Fill" StrokeThickness="0" StrokeShape="RoundRectangle 10"
                                                BackgroundColor="Black">
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer CommandParameter="{Binding .}" Tapped="to_charprofile"/>
                                            </Border.GestureRecognizers>
                                            
                                            <Grid>
                                                <Image x:Name="books_collection_image" Source="{Binding book_cover, FallbackValue='placeholder_image.png'}" Aspect="AspectFill" />
                                                <Border>
                                                    <Border.Background>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                            <GradientStop Color="#00000000" Offset="0.0"/>
                                                            <GradientStop Color="#99000000" Offset="1.0"/>
                                                        </LinearGradientBrush>
                                                    </Border.Background>
                                                </Border>
                                                
                                                <Grid VerticalOptions="End" Padding="8, 12" ColumnDefinitions="*, Auto"
                                                      BackgroundColor="{AppThemeBinding Light=#BFFFFFFF, Dark=#BF000000}">
                                                    <Label Grid.Column="0" Text="{Binding book_title}" VerticalOptions="Center" LineBreakMode="TailTruncation" MaxLines="1"
                                                           FontFamily="Poppins-Light" FontSize="12" TextColor="{AppThemeBinding Light=#2C2C2C, Dark=#EAEAEA}" />
                                                </Grid>
                                                
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                    
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                    </Border>    
                </VerticalStackLayout>
                
                <!-- CHARACTERS: Supporting -->
                <VerticalStackLayout Grid.Row="2" Spacing="0" VerticalOptions="Fill" HeightRequest="175">
                    <Label Text="Supporting" Grid.Row="0"
                           FontSize="12" FontFamily="Poppins-Black" TextColor="{AppThemeBinding Light=#202020, Dark=#F5F5F5}" />
                    <Border Grid.Row="1" HeightRequest="165" StrokeShape="RoundRectangle 5" StrokeThickness="0"
                        BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#1F1F1F}">
                            <CollectionView>
                                <CollectionView.ItemsLayout>
                                    <GridItemsLayout Orientation="Horizontal" />
                                </CollectionView.ItemsLayout>
                                
                                <CollectionView.ItemTemplate>
                                    <DataTemplate>
                                        <Border VerticalOptions="Fill" StrokeThickness="0" StrokeShape="RoundRectangle 10"
                                                BackgroundColor="Black">
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer CommandParameter="{Binding .}" Tapped="to_charprofile"/>
                                            </Border.GestureRecognizers>
                                            
                                            <Grid>
                                                <Image x:Name="books_collection_image" Source="{Binding book_cover, FallbackValue='placeholder_image.png'}" Aspect="AspectFill" />
                                                <Border>
                                                    <Border.Background>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                            <GradientStop Color="#00000000" Offset="0.0"/>
                                                            <GradientStop Color="#99000000" Offset="1.0"/>
                                                        </LinearGradientBrush>
                                                    </Border.Background>
                                                </Border>
                                                
                                                <Grid VerticalOptions="End" Padding="8, 12" ColumnDefinitions="*, Auto"
                                                      BackgroundColor="{AppThemeBinding Light=#BFFFFFFF, Dark=#BF000000}">
                                                    <Label Grid.Column="0" Text="{Binding book_title}" VerticalOptions="Center" LineBreakMode="TailTruncation" MaxLines="1"
                                                           FontFamily="Poppins-Light" FontSize="12" TextColor="{AppThemeBinding Light=#2C2C2C, Dark=#EAEAEA}" />
                                                </Grid>
                                                
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                    
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                    </Border>    
                </VerticalStackLayout>
                
                <!-- CHARACTERS: Minor -->
                <VerticalStackLayout Grid.Row="3" Spacing="0" VerticalOptions="Fill" HeightRequest="175">
                    <Label Text="Minor" Grid.Row="0"
                           FontSize="12" FontFamily="Poppins-Black" TextColor="{AppThemeBinding Light=#202020, Dark=#F5F5F5}" />
                    <Border Grid.Row="1" HeightRequest="165" StrokeShape="RoundRectangle 5" StrokeThickness="0"
                        BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#1F1F1F}">
                            <CollectionView>
                                <CollectionView.ItemsLayout>
                                    <GridItemsLayout Orientation="Horizontal" />
                                </CollectionView.ItemsLayout>
                                
                                <CollectionView.ItemTemplate>
                                    <DataTemplate>
                                        <Border VerticalOptions="Fill" StrokeThickness="0" StrokeShape="RoundRectangle 10"
                                                BackgroundColor="Black">
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer CommandParameter="{Binding .}" Tapped="to_charprofile"/>
                                            </Border.GestureRecognizers>
                                            
                                            <Grid>
                                                <Image x:Name="books_collection_image" Source="{Binding book_cover, FallbackValue='placeholder_image.png'}" Aspect="AspectFill" />
                                                <Border>
                                                    <Border.Background>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                            <GradientStop Color="#00000000" Offset="0.0"/>
                                                            <GradientStop Color="#99000000" Offset="1.0"/>
                                                        </LinearGradientBrush>
                                                    </Border.Background>
                                                </Border>
                                                
                                                <Grid VerticalOptions="End" Padding="8, 12" ColumnDefinitions="*, Auto"
                                                      BackgroundColor="{AppThemeBinding Light=#BFFFFFFF, Dark=#BF000000}">
                                                    <Label Grid.Column="0" Text="{Binding book_title}" VerticalOptions="Center" LineBreakMode="TailTruncation" MaxLines="1"
                                                           FontFamily="Poppins-Light" FontSize="12" TextColor="{AppThemeBinding Light=#2C2C2C, Dark=#EAEAEA}" />
                                                </Grid>
                                                
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                    
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                    </Border>    
                </VerticalStackLayout>
                    
            </Grid>         
        </ScrollView>

        <!-- ADD CHARACTERS -->
        <Border StrokeThickness="3" Grid.Row="2" HorizontalOptions="End" VerticalOptions="End" Margin="15, 30" StrokeShape="RoundRectangle 10" Padding="1"
                BackgroundColor="#4A90D9" Stroke="#234263">
            <Border.GestureRecognizers>
                <TapGestureRecognizer Tapped="on_addcharacter" />
            </Border.GestureRecognizers>
            <Border.Behaviors>
                <toolkit:TouchBehavior PressedScale="0.90" DefaultAnimationDuration="80"/>
            </Border.Behaviors>

            <HorizontalStackLayout Spacing="5" Padding="12, 8">
                <Image Source="icon_add.png" HeightRequest="20" WidthRequest="20" VerticalOptions="Center" />
                <Label Text="Add Character" VerticalOptions="Center" CharacterSpacing="-0.5"
                       FontFamily="Poppins-Black" FontSize="13" TextColor="#234263"/>
            </HorizontalStackLayout>
        </Border>

    </Grid>

</ContentView>