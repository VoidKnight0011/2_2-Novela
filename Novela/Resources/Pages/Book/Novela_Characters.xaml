<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:views="clr-namespace:Novela.Resources.Pages.Extra"
             x:Class="Novela.Resources.Pages.Book.Novela_Characters"
             Padding="0">

        <ScrollView>
            <VerticalStackLayout Padding="20" Spacing="20">

                <!-- Row#1: Title -->
                <Label Text="Characters" HorizontalTextAlignment="Center"
                       FontFamily="Poppins-Black" FontSize="24"
                       TextColor="{AppThemeBinding Light=#2C2C2C, Dark=#F4F4F4}" />

                <!-- Row#2: Add Character -->
                <Grid ColumnDefinitions="*, Auto" ColumnSpacing="8">
                    <Border Grid.Column="0" StrokeThickness="1" StrokeShape="RoundRectangle 8"
                            Padding="10,2.5" HeightRequest="40"
                            Stroke="{AppThemeBinding Light=#DADADA, Dark=#3F3F3F}"
                            BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E1E1E}">
                        <Entry x:Name="CharacterNameEntry"
                               Placeholder="New character name..."
                               FontFamily="Poppins-Regular" FontSize="8"
                               TextColor="{AppThemeBinding Light=#1F1F1F, Dark=#EAEAEA}"
                               PlaceholderColor="{AppThemeBinding Light=#9E9E9E, Dark=#757575}"
                               BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E1E1E}" />
                    </Border>

                    <ImageButton Grid.Column="1" Source="icon_add.png"
                                 HeightRequest="40" WidthRequest="40"
                                 CornerRadius="8" Padding="10"
                                 BackgroundColor="#4A90D9"
                                 Clicked="on_addcharacter" />
                </Grid>

                <!-- Row#3: Character List -->
                <CollectionView ItemsSource="{Binding Characters}"
                                EmptyView="No characters yet. Add one above.">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Vertical" ItemSpacing="10" />
                    </CollectionView.ItemsLayout>

                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border StrokeThickness="1" StrokeShape="RoundRectangle 10"
                                    Padding="10"
                                    Stroke="{AppThemeBinding Light=#DADADA, Dark=#3F3F3F}"
                                    BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E1E1E}">
                                <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="12">

                                    <!-- Portrait -->
                                    <Border Grid.Column="0" StrokeThickness="0"
                                            StrokeShape="RoundRectangle 6"
                                            HeightRequest="64" WidthRequest="64">
                                        <Image Source="placeholder_image.png" Aspect="AspectFill" />
                                    </Border>

                                    <!-- Name / Role / Description -->
                                    <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                        <Label Text="{Binding Name}"
                                               FontFamily="Poppins-Black" FontSize="11"
                                               TextColor="{AppThemeBinding Light=#2C2C2C, Dark=#F4F4F4}"
                                               LineBreakMode="TailTruncation" MaxLines="1"/>

                                        <Label Text="{Binding Role}"
                                               FontFamily="Poppins-Regular" FontSize="9"
                                               TextColor="#4A90D9"
                                               LineBreakMode="TailTruncation" MaxLines="1"/>

                                        <Label Text="{Binding Description}"
                                               FontFamily="Poppins-Light" FontSize="8"
                                               TextColor="{AppThemeBinding Light=#5C5C5C, Dark=#AAAAAA}"
                                               LineBreakMode="TailTruncation" MaxLines="2"/>
                                    </VerticalStackLayout>

                                    <!-- Delete Button -->
                                    <ImageButton Grid.Column="2"
                                                 Source="icon_delete.png"
                                                 HeightRequest="24" WidthRequest="24"
                                                 Padding="4" CornerRadius="6"
                                                 BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#2A2A2A}"
                                                 Clicked="on_deletecharacter"
                                                 CommandParameter="{Binding .}"
                                                 VerticalOptions="Center" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </VerticalStackLayout>
        </ScrollView>

</ContentView>