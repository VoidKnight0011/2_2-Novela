<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Novela.Resources.Pages.Book.Novela_Characters"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             Padding="0"
             BackgroundColor="{AppThemeBinding Light=#F4F4F4, Dark=#2C2C2C}">
    
    
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="22">

            <Button BackgroundColor="Blue" Clicked="to_characterprofile" />
            
            <!-- Protagonists -->
            <Grid RowDefinitions="Auto,*" RowSpacing="6">

                <Label Grid.Row="0"
                       Text="Protagonists"
                       FontSize="12"
                       FontFamily="Poppins-Black"
                       TextColor="{AppThemeBinding Light=#2C2C2C, Dark=#F4F4F4}" />

                <Border Grid.Row="1"
                        Padding="12"
                        HeightRequest="145"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 12"
                        BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E1E1E}"
                        Stroke="{AppThemeBinding Light=#DADADA, Dark=#3F3F3F}">

                    <Grid>

                        <CollectionView ItemsSource="{Binding protagonist_characters}">
                            <CollectionView.ItemsLayout>
                                <LinearItemsLayout Orientation="Horizontal"
                                                   ItemSpacing="10"/>
                            </CollectionView.ItemsLayout>

                            <CollectionView.ItemTemplate>
                                <DataTemplate>

                                    <Border WidthRequest="90"
                                            Padding="8"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 10"
                                            BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#2A2A2A}">

                                        <VerticalStackLayout Spacing="6">

                                            <Border HeightRequest="70"
                                                    WidthRequest="70"
                                                    HorizontalOptions="Center"
                                                    StrokeThickness="0"
                                                    StrokeShape="RoundRectangle 10"
                                                    BackgroundColor="#3A3A3A">

                                                <Image Source="{Binding character_image}"
                                                       Aspect="AspectFill"/>
                                            </Border>

                                            <Label Text="{Binding character_name}"
                                                   FontSize="8"
                                                   HorizontalTextAlignment="Center"
                                                   LineBreakMode="TailTruncation"
                                                   MaxLines="1"
                                                   FontFamily="Poppins-Regular"
                                                   TextColor="{AppThemeBinding Light=#1F1F1F, Dark=#EAEAEA}" />

                                        </VerticalStackLayout>

                                    </Border>

                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>

                        <Label Text="No protagonists added yet..."
                               IsVisible="{Binding protagonist_empty}"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"
                               FontSize="8"
                               FontFamily="Poppins-Regular"
                               TextColor="#777777"/>

                    </Grid>

                </Border>

            </Grid>

            <!-- Supporting -->
            <Grid RowDefinitions="Auto,*" RowSpacing="6">

                <Label Grid.Row="0"
                       Text="Supporting"
                       FontSize="12"
                       FontFamily="Poppins-Black"
                       TextColor="{AppThemeBinding Light=#2C2C2C, Dark=#F4F4F4}" />

                <Border Grid.Row="1"
                        Padding="12"
                        HeightRequest="145"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 12"
                        BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E1E1E}"
                        Stroke="{AppThemeBinding Light=#DADADA, Dark=#3F3F3F}">

                    <Grid>

                        <CollectionView ItemsSource="{Binding supporting_characters}">
                            <CollectionView.ItemsLayout>
                                <LinearItemsLayout Orientation="Horizontal"
                                                   ItemSpacing="10"/>
                            </CollectionView.ItemsLayout>

                            <CollectionView.ItemTemplate>
                                <DataTemplate>

                                    <Border WidthRequest="90"
                                            Padding="8"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 10"
                                            BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#2A2A2A}">

                                        <VerticalStackLayout Spacing="6">

                                            <Border HeightRequest="70"
                                                    WidthRequest="70"
                                                    HorizontalOptions="Center"
                                                    StrokeThickness="0"
                                                    StrokeShape="RoundRectangle 10"
                                                    BackgroundColor="#3A3A3A">

                                                <Image Source="{Binding character_image}"
                                                       Aspect="AspectFill"/>
                                            </Border>

                                            <Label Text="{Binding character_name}"
                                                   FontSize="8"
                                                   HorizontalTextAlignment="Center"
                                                   LineBreakMode="TailTruncation"
                                                   MaxLines="1"
                                                   FontFamily="Poppins-Regular"
                                                   TextColor="{AppThemeBinding Light=#1F1F1F, Dark=#EAEAEA}" />

                                        </VerticalStackLayout>

                                    </Border>

                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>

                        <Label Text="No supporting characters added yet..."
                               IsVisible="{Binding supporting_empty}"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"
                               FontSize="8"
                               FontFamily="Poppins-Regular"
                               TextColor="#777777"/>

                    </Grid>

                </Border>

            </Grid>

            <!-- Antagonists -->
            <Grid RowDefinitions="Auto,*" RowSpacing="6">

                <Label Grid.Row="0"
                       Text="Antagonists"
                       FontSize="12"
                       FontFamily="Poppins-Black"
                       TextColor="{AppThemeBinding Light=#2C2C2C, Dark=#F4F4F4}" />

                <Border Grid.Row="1"
                        Padding="12"
                        HeightRequest="145"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 12"
                        BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E1E1E}"
                        Stroke="{AppThemeBinding Light=#DADADA, Dark=#3F3F3F}">

                    <Grid>

                        <CollectionView ItemsSource="{Binding antagonist_characters}">
                            <CollectionView.ItemsLayout>
                                <LinearItemsLayout Orientation="Horizontal"
                                                   ItemSpacing="10"/>
                            </CollectionView.ItemsLayout>

                            <CollectionView.ItemTemplate>
                                <DataTemplate>

                                    <Border WidthRequest="90"
                                            Padding="8"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 10"
                                            BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#2A2A2A}">

                                        <VerticalStackLayout Spacing="6">

                                            <Border HeightRequest="70"
                                                    WidthRequest="70"
                                                    HorizontalOptions="Center"
                                                    StrokeThickness="0"
                                                    StrokeShape="RoundRectangle 10"
                                                    BackgroundColor="#3A3A3A">

                                                <Image Source="{Binding character_image}"
                                                       Aspect="AspectFill"/>
                                            </Border>

                                            <Label Text="{Binding character_name}"
                                                   FontSize="8"
                                                   HorizontalTextAlignment="Center"
                                                   LineBreakMode="TailTruncation"
                                                   MaxLines="1"
                                                   FontFamily="Poppins-Regular"
                                                   TextColor="{AppThemeBinding Light=#1F1F1F, Dark=#EAEAEA}" />

                                        </VerticalStackLayout>

                                    </Border>

                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>

                        <Label Text="No antagonists added yet..."
                               IsVisible="{Binding antagonist_empty}"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"
                               FontSize="8"
                               FontFamily="Poppins-Regular"
                               TextColor="#777777"/>

                    </Grid>

                </Border>

            </Grid>

            <!-- Minor -->
            <Grid RowDefinitions="Auto,*" RowSpacing="6">

                <Label Grid.Row="0"
                       Text="Minor Characters"
                       FontSize="12"
                       FontFamily="Poppins-Black"
                       TextColor="{AppThemeBinding Light=#2C2C2C, Dark=#F4F4F4}" />

                <Border Grid.Row="1"
                        Padding="12"
                        HeightRequest="145"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 12"
                        BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E1E1E}"
                        Stroke="{AppThemeBinding Light=#DADADA, Dark=#3F3F3F}">

                    <Grid>

                        <CollectionView ItemsSource="{Binding minor_characters}">
                            <CollectionView.ItemsLayout>
                                <LinearItemsLayout Orientation="Horizontal"
                                                   ItemSpacing="10"/>
                            </CollectionView.ItemsLayout>

                            <CollectionView.ItemTemplate>
                                <DataTemplate>

                                    <Border WidthRequest="90"
                                            Padding="8"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 10"
                                            BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#2A2A2A}">

                                        <VerticalStackLayout Spacing="6">

                                            <Border HeightRequest="70"
                                                    WidthRequest="70"
                                                    HorizontalOptions="Center"
                                                    StrokeThickness="0"
                                                    StrokeShape="RoundRectangle 10"
                                                    BackgroundColor="#3A3A3A">

                                                <Image Source="{Binding character_image}"
                                                       Aspect="AspectFill"/>
                                            </Border>

                                            <Label Text="{Binding character_name}"
                                                   FontSize="8"
                                                   HorizontalTextAlignment="Center"
                                                   LineBreakMode="TailTruncation"
                                                   MaxLines="1"
                                                   FontFamily="Poppins-Regular"
                                                   TextColor="{AppThemeBinding Light=#1F1F1F, Dark=#EAEAEA}" />

                                        </VerticalStackLayout>

                                    </Border>

                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>

                        <Label Text="No minor characters added yet..."
                               IsVisible="{Binding minor_empty}"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"
                               FontSize="8"
                               FontFamily="Poppins-Regular"
                               TextColor="#777777"/>

                    </Grid>

                </Border>

            </Grid>
            
            
            
            <Border StrokeThickness="4" Grid.Row="2" HorizontalOptions="End" VerticalOptions="End" Margin="16, 20" StrokeShape="RoundRectangle 10" Padding="2.5"
                    BackgroundColor="{AppThemeBinding Light=#2C2C2C, Dark=#F4F4F4}">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="on_addcharacter" />
                </Border.GestureRecognizers>
                <Border.Behaviors>
                    <toolkit:TouchBehavior PressedScale="0.90" DefaultAnimationDuration="80"/>
                </Border.Behaviors>

                <HorizontalStackLayout Spacing="5" Padding="12, 8">
                    <Image Source="icon_add.png" HeightRequest="20" WidthRequest="20" VerticalOptions="Center" />
                    <Label Text="Add Book" VerticalOptions="Center"
                           FontFamily="Poppins-Black" FontSize="13" TextColor="#234263"/>
                </HorizontalStackLayout>
            </Border>
            
            

        </VerticalStackLayout>
    </ScrollView>

</ContentView>