<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Novela.Resources.Pages.Book.Novela_Characters"
             BackgroundColor="#191919">

    <Grid ColumnDefinitions="*">
        

        <!-- MAIN CONTENT -->
        <ScrollView Grid.Column="1">

            <VerticalStackLayout Padding="30"
                                 Spacing="30">

                <!-- HEADER -->
                <VerticalStackLayout Spacing="4">
                    <Label Text="Characters"
                           FontSize="34"
                           FontAttributes="Bold"
                           TextColor="White"/>

                    <Label Text="Manage protagonists, antagonists, and supporting cast."
                           FontSize="14"
                           TextColor="#9A9A9A"/>
                </VerticalStackLayout>

                <!-- PROTAGONIST -->
                <VerticalStackLayout Spacing="15">

                    <Grid ColumnDefinitions="*,auto">
                        <Label Text="Protagonists"
                               FontSize="22"
                               FontAttributes="Bold"
                               TextColor="White"/>

                        <Border Grid.Column="1"
                                BackgroundColor="#2C2C2C"
                                Padding="10,6"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 10">

                            <Label Text="+ Add"
                                   TextColor="White"/>
                        </Border>
                    </Grid>

                    <CollectionView>
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Horizontal"
                                               ItemSpacing="15"/>
                        </CollectionView.ItemsLayout>

                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border WidthRequest="180"
                                        HeightRequest="240"
                                        BackgroundColor="#252525"
                                        Padding="15"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 16">

                                    <VerticalStackLayout Spacing="12">

                                        <!-- Portrait Placeholder -->
                                        <Border HeightRequest="120"
                                                BackgroundColor="#353535"
                                                StrokeThickness="0"
                                                StrokeShape="RoundRectangle 12"/>

                                        <VerticalStackLayout Spacing="4">

                                            <Label Text="Character Name"
                                                   FontSize="18"
                                                   FontAttributes="Bold"
                                                   TextColor="White"/>

                                            <Label Text="Main protagonist placeholder description."
                                                   FontSize="13"
                                                   TextColor="#AAAAAA"
                                                   LineBreakMode="TailTruncation"
                                                   MaxLines="3"/>
                                        </VerticalStackLayout>

                                    </VerticalStackLayout>

                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>

                        <!-- TEMP PLACEHOLDERS -->


                    </CollectionView>
                </VerticalStackLayout>

                <!-- SUPPORTING -->
                <VerticalStackLayout Spacing="15">

                    <Label Text="Supporting Characters"
                           FontSize="22"
                           FontAttributes="Bold"
                           TextColor="White"/>

                    <CollectionView HeightRequest="170">
                        <CollectionView.ItemsLayout>
                            <GridItemsLayout Orientation="Vertical"
                                             Span="3"
                                             HorizontalItemSpacing="15"
                                             VerticalItemSpacing="15"/>
                        </CollectionView.ItemsLayout>

                        <CollectionView.ItemTemplate>
                            <DataTemplate>

                                <Border BackgroundColor="#252525"
                                        Padding="14"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 14">

                                    <HorizontalStackLayout Spacing="12">

                                        <Border WidthRequest="50"
                                                HeightRequest="50"
                                                BackgroundColor="#353535"
                                                StrokeThickness="0"
                                                StrokeShape="RoundRectangle 25"/>

                                        <VerticalStackLayout>
                                            <Label Text="Supporting Character"
                                                   FontAttributes="Bold"
                                                   TextColor="White"/>

                                            <Label Text="Role / relationship"
                                                   FontSize="12"
                                                   TextColor="#9A9A9A"/>
                                        </VerticalStackLayout>

                                    </HorizontalStackLayout>

                                </Border>

                            </DataTemplate>
                        </CollectionView.ItemTemplate>



                    </CollectionView>

                </VerticalStackLayout>

                <!-- ANTAGONISTS -->
                <VerticalStackLayout Spacing="15">

                    <Label Text="Antagonists"
                           FontSize="22"
                           FontAttributes="Bold"
                           TextColor="White"/>

                    <Border HeightRequest="140"
                            BackgroundColor="#252525"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 16">

                        <Grid>
                            <Label Text="Temporary antagonist section..."
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"
                                   TextColor="#777777"/>
                        </Grid>

                    </Border>

                </VerticalStackLayout>

            </VerticalStackLayout>

        </ScrollView>

    </Grid>

</ContentView>