<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:extra="clr-namespace:Novela.Resources.Pages.Extra"
             xmlns:book="clr-namespace:Novela.Resources.Pages.Book"
             x:Class="Novela.Resources.Pages.Book.Novela_Editor">
    
    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Settings" Order="Secondary" Priority="0" Clicked="to_settings" />
        <ToolbarItem Text="About" Order="Secondary" Priority="1" Clicked="to_about" />
        <ToolbarItem Text="Logout" Order="Secondary" Priority="2" Clicked="to_logout" />
    </ContentPage.ToolbarItems>
    
    <Grid>
        <extra:Book_Sidebar ZIndex="2" x:Name="Sidebar" HorizontalOptions="Start" 
                            VerticalOptions="Fill" SafeAreaEdges="None"/>
        
        <ContentView x:Name="Editor_ContentArea" Margin="60, 0, 0, 0" />
    </Grid>    
    
</ContentPage>