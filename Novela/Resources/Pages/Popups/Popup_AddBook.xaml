<?xml version="1.0" encoding="utf-8"?>

<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="Novela.Resources.Pages.Popups.Popup_AddBook">

    <Grid RowDefinitions="Auto,Auto,Auto,*,Auto"
          ColumnDefinitions="*">


        <!-- Header -->
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
            <Label Text="Add Book" Grid.Column="0"/>
            <ImageButton Grid.Column="1"/>
        </Grid>
	
        <!-- Add Book Upload -->
        <Grid Grid.Row="1">
            <Label Text="Title"/>
            <Entry Placeholder="Enter Book Title" Margin="0,20,0,0"/>
        </Grid>


        <!-- Synopsis -->
        <Grid Grid.Row="2">
            <Label Text="Synopsis"/>
            <Editor Placeholder="Enter Book Description..." Margin="0,20,0,0"/>
        </Grid>


        <!-- Buttons -->
        <Grid Grid.Row="4" ColumnDefinitions="*,*">
            <Button Text="Cancel" Grid.Column="0"/>
            <Button Text="Save" Grid.Column="1"/>
        </Grid>


    </Grid>
    
</toolkit:Popup>