<?xml version="1.0" encoding="utf-8"?>

<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Novela.Resources.Pages.Extra.Book_Header"
             HorizontalOptions="Fill" Padding="10" ZIndex="0"
             BackgroundColor="{AppThemeBinding Light=#a3a3a3, Dark=#212121t}">
    
    <Grid HorizontalOptions="Fill" Padding="10" ZIndex="0"
          BackgroundColor="{AppThemeBinding Light=#a3a3a3, Dark=#212121t}">
        <Label IsVisible="True" x:Name="book_title_label" Text="{Binding _currentBook.book_title}" VerticalOptions="Center" HorizontalTextAlignment="Center"
               TextColor="{AppThemeBinding Light=#2C2C2C, Dark=#EAEAEA}" FontFamily="Poppins-Black" FontSize="12">
            <Label.GestureRecognizers>
                <TapGestureRecognizer Tapped="edit_title" />
            </Label.GestureRecognizers>
        </Label>    
        <Entry IsVisible="False" x:Name="book_title_entry" Text="{Binding _currentBook.book_title}" VerticalOptions="Center" HorizontalTextAlignment="Center" Unfocused="book_entry_unfocused"
               TextColor="{AppThemeBinding Light=#2C2C2C, Dark=#EAEAEA}" FontFamily="Poppins-Black" FontSize="12" />
        <ImageButton Source="icon_eye_opened.png" HeightRequest="25" WidthRequest="25" MinimumHeightRequest="25" MinimumWidthRequest="25" VerticalOptions="Center" HorizontalOptions="End" />
    </Grid>
    
</ContentView>