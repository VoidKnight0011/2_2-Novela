<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="Novela.Resources.Pages.Extra.Book_Sidebar"
             x:Name="Novela_Sidebar"
             VerticalOptions="Fill"
             BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#191919}">

    <Border StrokeThickness="0">
        <Border.StrokeShape>
            <RoundRectangle CornerRadius="0,0,50,0"/>
        </Border.StrokeShape>

        <Grid RowDefinitions="Auto, *" Padding="10">

            <!-- Header Section -->
            <Grid Grid.Row="0" ColumnDefinitions="*, Auto" Margin="0,0,0,15">

                <!-- Back to Library -->
                <Border Grid.Column="0" Padding="10" StrokeThickness="0"
                        BackgroundColor="Transparent">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="to_dashboard" />
                    </Border.GestureRecognizers>
                    <Border.Behaviors>
                        <toolkit:TouchBehavior
                            PressedBackgroundColor="#22FFFFFF"
                            PressedScale="0.97"
                            DefaultAnimationDuration="80"/>
                    </Border.Behaviors>
                    <HorizontalStackLayout Spacing="8">
                        <Image Source="sidebar_return.png" HeightRequest="20" WidthRequest="20" VerticalOptions="Center" />
                        <Label Text="Return" FontSize="10.5" VerticalOptions="Center"
                               TextColor="#4A90D9" FontFamily="Poppins-Black" />
                    </HorizontalStackLayout>
                </Border>

                <!-- Switch Menu -->
                <Border Grid.Column="1" StrokeThickness="0" BackgroundColor="Transparent" VerticalOptions="Center">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="on_togglesidebar"/>
                    </Border.GestureRecognizers>
                    <Border.Behaviors>
                        <toolkit:TouchBehavior
                            PressedBackgroundColor="#22FFFFFF"
                            PressedScale="0.97"
                            DefaultAnimationDuration="80"/>
                    </Border.Behaviors>
                    <Image x:Name="toggle_sidebar" Source="icon_point.png" HeightRequest="40" WidthRequest="40"
                           Aspect="AspectFit" VerticalOptions="Center" BackgroundColor="Transparent" />
                </Border>
            </Grid>

            <!-- Navigation Items -->
            <VerticalStackLayout Grid.Row="1" Spacing="5">

                <!-- Overview -->
                <Border x:Name="border_overview" Padding="10" StrokeThickness="0" BackgroundColor="Transparent">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="to_overview" />
                    </Border.GestureRecognizers>
                    <Border.Behaviors>
                        <toolkit:TouchBehavior x:Name="touch_overview"
                            PressedBackgroundColor="#22FFFFFF"
                            PressedScale="0.97"
                            DefaultAnimationDuration="80"/>
                    </Border.Behaviors>
                    <HorizontalStackLayout Spacing="10">
                        <Image Source="sidebar_overview.png" HeightRequest="22.5" WidthRequest="22.5" VerticalOptions="Center" />
                        <Label Text="Overview" FontSize="10.5" VerticalOptions="Center"
                               TextColor="#4A90D9" FontFamily="Poppins-Black" />
                    </HorizontalStackLayout>
                </Border>

                <!-- Characters -->
                <Border x:Name="border_characters" Padding="10" StrokeThickness="0" BackgroundColor="Transparent">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="to_characters" />
                    </Border.GestureRecognizers>
                    <Border.Behaviors>
                        <toolkit:TouchBehavior x:Name="touch_characters"
                            PressedBackgroundColor="#22FFFFFF"
                            PressedScale="0.97"
                            DefaultAnimationDuration="80"/>
                    </Border.Behaviors>
                    <HorizontalStackLayout Spacing="10">
                        <Image Source="sidebar_characters.png" HeightRequest="22.5" WidthRequest="22.5" VerticalOptions="Center" />
                        <Label Text="Characters" FontSize="10.5" VerticalOptions="Center"
                               TextColor="#4A90D9" FontFamily="Poppins-Black" />
                    </HorizontalStackLayout>
                </Border>

                <!-- Timeline -->
                <Border x:Name="border_timeline" Padding="10" StrokeThickness="0" BackgroundColor="Transparent">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="to_timeline" />
                    </Border.GestureRecognizers>
                    <Border.Behaviors>
                        <toolkit:TouchBehavior x:Name="touch_timeline"
                            PressedBackgroundColor="#22FFFFFF"
                            PressedScale="0.97"
                            DefaultAnimationDuration="80"/>
                    </Border.Behaviors>
                    <HorizontalStackLayout Spacing="10">
                        <Image Source="sidebar_timeline.png" HeightRequest="22.5" WidthRequest="22.5" VerticalOptions="Center" />
                        <Label Text="Timeline" FontSize="10.5" VerticalOptions="Center"
                               TextColor="#4A90D9" FontFamily="Poppins-Black" />
                    </HorizontalStackLayout>
                </Border>

                <!-- Manuscript -->
                <Border x:Name="border_manuscript" Padding="10" StrokeThickness="0" BackgroundColor="Transparent">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="to_manuscript" />
                    </Border.GestureRecognizers>
                    <Border.Behaviors>
                        <toolkit:TouchBehavior x:Name="touch_manuscript"
                            PressedBackgroundColor="#22FFFFFF"
                            PressedScale="0.97"
                            DefaultAnimationDuration="80"/>
                    </Border.Behaviors>
                    <HorizontalStackLayout Spacing="10">
                        <Image Source="sidebar_manuscript.png" HeightRequest="22.5" WidthRequest="22.5" VerticalOptions="Center" />
                        <Label Text="Manuscript" FontSize="10.5" VerticalOptions="Center"
                               TextColor="#4A90D9" FontFamily="Poppins-Black" />
                    </HorizontalStackLayout>
                </Border>

                <!-- Appendices -->
                <Border x:Name="border_appendices" Padding="10" StrokeThickness="0" BackgroundColor="Transparent">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="to_appendices" />
                    </Border.GestureRecognizers>
                    <Border.Behaviors>
                        <toolkit:TouchBehavior x:Name="touch_appendices"
                            PressedBackgroundColor="#22FFFFFF"
                            PressedScale="0.97"
                            DefaultAnimationDuration="80"/>
                    </Border.Behaviors>
                    <HorizontalStackLayout Spacing="10">
                        <Image Source="sidebar_appendices.png" HeightRequest="20" WidthRequest="20" VerticalOptions="Center" />
                        <Label Text="Appendices" FontSize="10.5" VerticalOptions="Center"
                               TextColor="#4A90D9" FontFamily="Poppins-Black" />
                    </HorizontalStackLayout>
                </Border>

            </VerticalStackLayout>

        </Grid>
    </Border>

</ContentView>
