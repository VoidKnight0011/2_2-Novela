<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Novela.Resources.Pages.Extra.Book_Sidebar"
             x:Name="Novela_Sidebar"
             BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#191919}"
             >
    
    <Grid RowDefinitions="Auto, *" Padding="10">
        
        <!-- Header Section -->
        <Grid Grid.Row="0" ColumnDefinitions="*, Auto" Margin="0,0,0,15">
            
            <!-- Back to Library -->
            <Border Grid.Column="0" Padding="10" StrokeThickness="0"
                    BackgroundColor="Transparent">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="to_dashboard" />
                </Border.GestureRecognizers>
                
                <HorizontalStackLayout Spacing="8">
                    <Image Source="sidebar_return.png" HeightRequest="20" WidthRequest="20" VerticalOptions="Center" />
                    <Label Text="Return" FontSize="10.5" VerticalOptions="Center"
                           TextColor="#4A90D9" FontFamily="Poppins-Black" />
                </HorizontalStackLayout>
            </Border>
            
            <!-- Kebab Menu -->
            <ImageButton x:Name="toggle_sidebar" Grid.Column="1" Source="icon_point.png"  HeightRequest="20" WidthRequest="20" Padding="0" Aspect="AspectFit" VerticalOptions="Center" Clicked="on_togglesidebar"
                         BackgroundColor="Transparent" />
        </Grid>

        <!-- Navigation Items -->
        <VerticalStackLayout Grid.Row="1" Spacing="5">
            
            <!-- Overview -->
            <Border x:Name="button_overview" Padding="10" StrokeThickness="0"
                    BackgroundColor="{AppThemeBinding Light=#F0F0F0, Dark=#2C2C2C}">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="to_overview" />
                </Border.GestureRecognizers>
                <HorizontalStackLayout Spacing="10">
                    <Image Source="sidebar_overview.png" HeightRequest="17.5" WidthRequest="17.5" VerticalOptions="Center" />
                    <Label Text="Overview" FontSize="10.5" VerticalOptions="Center"
                           TextColor="#4A90D9" FontFamily="Poppins-Black" />
                </HorizontalStackLayout>
            </Border>

            <!-- Characters -->
            <Border x:Name="button_characters" Padding="10" StrokeThickness="0"
                    BackgroundColor="Transparent">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="to_characters" />
                </Border.GestureRecognizers>
                <HorizontalStackLayout Spacing="10">
                    <Image Source="sidebar_characters.png" HeightRequest="17.5" WidthRequest="17.5" VerticalOptions="Center" />
                    <Label Text="Characters" FontSize="10.5" VerticalOptions="Center"
                           TextColor="#4A90D9" FontFamily="Poppins-Black" />
                </HorizontalStackLayout>
            </Border>

            <!-- Timeline -->
            <Border x:Name="button_timeline" Padding="10" StrokeThickness="0"
                    BackgroundColor="Transparent">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="to_timeline" />
                </Border.GestureRecognizers>
                <HorizontalStackLayout Spacing="10">
                    <Image Source="sidebar_timeline.png" HeightRequest="17.5" WidthRequest="17.5" VerticalOptions="Center" />
                    <Label Text="Timeline" FontSize="10.5" VerticalOptions="Center"
                           TextColor="#4A90D9" FontFamily="Poppins-Black" />
                </HorizontalStackLayout>
            </Border>

            <!-- Manuscript -->
            <Border x:Name="button_manuscript" Padding="10" StrokeThickness="0"
                    BackgroundColor="Transparent">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="to_manuscript" />
                </Border.GestureRecognizers>
                <HorizontalStackLayout Spacing="10">
                    <Image Source="sidebar_manuscript.png" HeightRequest="17.5" WidthRequest="17.5" VerticalOptions="Center" />
                    <Label Text="Manuscript" FontSize="10.5" VerticalOptions="Center"
                           TextColor="#4A90D9" FontFamily="Poppins-Black" />
                </HorizontalStackLayout>
            </Border>

            <!-- Appendices -->
            <Border x:Name="button_appendices" Padding="10" StrokeThickness="0"
                    BackgroundColor="Transparent">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="to_appendices" />
                </Border.GestureRecognizers>
                <HorizontalStackLayout Spacing="10">
                    <Image Source="sidebar_appendices.png" HeightRequest="20" WidthRequest="20" VerticalOptions="Center" />
                    <Label Text="Appendices" FontSize="10.5" VerticalOptions="Center"
                           TextColor="#4A90D9" FontFamily="Poppins-Black" />
                </HorizontalStackLayout>
            </Border>
            
        </VerticalStackLayout>
        
    </Grid>
    
</ContentView>